{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "WebFetch(domain:www.stackage.org)",
      "Bash(stack build:*)",
      "Bash(stack test:*)",
      "Bash(bash:*)",
      "Bash(hlint:*)",
      "Bash(stack:*)",
      "WebFetch(domain:github.com)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(sghci:*)",
      "Bash(stack test:*)",
      "Bash(make:*)",
      "Bash(man:*)"
    ],
    "defaultMode": "plan"
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$TMUX\" ]; then printf '\\033Ptmux;\\033\\033]9;Claude Code needs input\\a\\033\\\\' > /dev/tty; else printf '\\033]9;Claude Code needs input\\a' > /dev/tty; fi"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "editorMode": "vim",
  "fileCheckpointingEnabled": false
}
